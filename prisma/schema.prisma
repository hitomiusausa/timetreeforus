generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  loginId      String   @unique @map("login_id")
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions       Session[]
  createdFamilies FamilySpace[]   @relation("FamilyCreator")
  memberships    FamilyMember[]
  createdEvents  Event[]          @relation("EventCreator")
  assignedEvents Event[]          @relation("EventAssignee")
  comments       EventComment[]
  notifications  Notification[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model FamilySpace {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @map("invite_code")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  creator       User            @relation("FamilyCreator", fields: [createdBy], references: [id])
  members       FamilyMember[]
  categories    EventCategory[]
  events        Event[]
  notifications Notification[]

  @@map("family_spaces")
}

model FamilyMember {
  id            String   @id @default(uuid())
  familySpaceId String   @map("family_space_id")
  userId        String   @map("user_id")
  role          String   @default("member")
  color         String   @default("#2f80ed")
  createdAt     DateTime @default(now()) @map("created_at")

  familySpace FamilySpace @relation(fields: [familySpaceId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familySpaceId, userId])
  @@index([userId, createdAt])
  @@map("family_members")
}

model EventCategory {
  id            String @id @default(uuid())
  familySpaceId String @map("family_space_id")
  name          String
  color         String
  sortOrder     Int    @default(0) @map("sort_order")

  familySpace FamilySpace @relation(fields: [familySpaceId], references: [id], onDelete: Cascade)
  events      Event[]

  @@index([familySpaceId, sortOrder])
  @@map("event_categories")
}

model Event {
  id            String    @id @default(uuid())
  familySpaceId String    @map("family_space_id")
  categoryId    String?   @map("category_id")
  title         String
  startsAt      DateTime  @map("starts_at")
  endsAt        DateTime  @map("ends_at")
  isAllDay      Boolean   @default(false) @map("is_all_day")
  location      String?
  note          String?
  createdBy     String    @map("created_by")
  assignedTo    String?   @map("assigned_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  familySpace   FamilySpace     @relation(fields: [familySpaceId], references: [id], onDelete: Cascade)
  category      EventCategory?  @relation(fields: [categoryId], references: [id])
  creator       User            @relation("EventCreator", fields: [createdBy], references: [id])
  assignee      User?           @relation("EventAssignee", fields: [assignedTo], references: [id])
  comments      EventComment[]
  notifications Notification[]

  @@index([familySpaceId, startsAt])
  @@index([familySpaceId, deletedAt, startsAt])
  @@map("events")
}

model EventComment {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("event_comments")
}

model Notification {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  familySpaceId String    @map("family_space_id")
  eventId       String?   @map("event_id")
  type          String
  title         String
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  familySpace FamilySpace @relation(fields: [familySpaceId], references: [id], onDelete: Cascade)
  event       Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}
